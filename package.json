{
  "name": "ZTools",
  "version": "2.6.1",
  "description": "ZTools",
  "main": "./out/main/index.js",
  "author": "lzx8589561",
  "homepage": "https://github.com/ZToolsCenter/ZTools",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZToolsCenter/ZTools.git"
  },
  "bugs": {
    "url": "https://github.com/ZToolsCenter/ZTools/issues"
  },
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "node -e \"if (process.platform === 'win32') require('child_process').execSync('chcp 65001 >nul 2>&1', {stdio: 'ignore'})\" && electron-vite preview",
    "dev:main": "node -e \"if (process.platform === 'win32') require('child_process').execSync('chcp 65001 >nul 2>&1', {stdio: 'ignore'})\" && electron-vite dev",
    "dev:setting": "cd internal-plugins/setting && pnpm dev",
    "dev": "concurrently -n \"main,setting\" -c \"blue,green\" \"pnpm dev:main\" \"pnpm dev:setting\"",
    "kill": "pkill -9 Electron",
    "dev:clean": "pnpm kill && pnpm dev",
    "build": "pnpm typecheck && pnpm build:setting && electron-vite build",
    "build:setting": "cd internal-plugins/setting && pnpm build",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "cross-env ZTOOLS_TARGET_PLATFORM=win32 pnpm build && electron-builder --win --publish never",
    "build:mac": "cross-env ZTOOLS_TARGET_PLATFORM=darwin pnpm build && electron-builder --mac --publish never",
    "build:mac:x64": "cross-env ZTOOLS_TARGET_PLATFORM=darwin pnpm build && electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "cross-env ZTOOLS_TARGET_PLATFORM=darwin pnpm build && electron-builder --mac --arm64 --publish never",
    "build:mac:update": "cross-env ZTOOLS_TARGET_PLATFORM=darwin pnpm build && electron-builder --mac --dir",
    "build:linux": "cross-env ZTOOLS_TARGET_PLATFORM=linux pnpm build && electron-builder --linux",
    "build:linux:x64": "cross-env ZTOOLS_TARGET_PLATFORM=linux pnpm build && electron-builder --linux --x64",
    "build:linux:arm64": "cross-env ZTOOLS_TARGET_PLATFORM=linux pnpm build && electron-builder --linux --arm64",
    "updater": "node scripts/updater.mjs",
    "test": "vitest run",
    "test:windows-scanner": "electron scripts/compare-windows-scanner.cjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync-api-types": "node scripts/sync-api-types.js",
    "check-api-types": "node -p \"require('./ztools-api-types/package.json')['utools-version']\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "postinstall": "pnpm run hooks:install || true"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/asar": "^4.1.0",
    "adm-zip": "^0.5.16",
    "chokidar": "^4.0.3",
    "electron-log": "^5.4.3",
    "electron-updater": "6.8.9",
    "fuse.js": "^7.0.0",
    "lmdb": "^3.4.4",
    "marked": "^17.0.1",
    "minimatch": "10.1.1",
    "openai": "^6.25.0",
    "pinia": "^3.0.4",
    "pinyin-pro": "^3.24.2",
    "simple-plist": "^1.3.1",
    "tar": "^7.5.9",
    "turndown": "^7.2.2",
    "uiohook-napi": "^1.5.4",
    "uuid": "^13.0.0",
    "vuedraggable": "^4.1.0",
    "winreg": "^1.2.5",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.18.6",
    "@types/tar": "^7.0.87",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "41.4.0",
    "electron-builder": "26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-vue": "^10.4.0",
    "fs-extra": "^11.3.4",
    "node-gyp": "^12.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.21",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "uiohook-napi"
    ]
  }
}
